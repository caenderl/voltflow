# Anker Solix Zugangsdaten - Kopie nach .env und ausfuellen
ANKERUSER="deine@mail.de"
ANKERPASSWORD="dein-passwort"   # Sonderzeichen -> in Anfuehrungszeichen!
ANKERCOUNTRY="DE"

# DB-Credentials (Quelle der Wahrheit; vom DB-Container und den Apps genutzt)
POSTGRES_USER="poke"
POSTGRES_PASSWORD="poke"
POSTGRES_DB="poke"
# Für lokal (außerhalb Docker) laufende Apps; im Container wird die URL aus den
# POSTGRES_*-Werten mit Host "db" zusammengesetzt (siehe docker-compose.prod.yml).
DATABASE_URL="postgresql://poke:poke@localhost:5432/poke"
