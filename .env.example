# Anker Solix credentials - copy to .env and fill in
ANKERUSER="your@mail.com"
ANKERPASSWORD="your-password"   # special characters -> wrap in quotes!
ANKERCOUNTRY="DE"

# DB credentials (source of truth; used by the DB container and the apps)
POSTGRES_USER="poke"
POSTGRES_PASSWORD="poke"
POSTGRES_DB="poke"
# For apps running locally (outside Docker); inside containers the URL is built
# from the POSTGRES_* values with host "db" (see docker-compose.prod.yml).
DATABASE_URL="postgresql://poke:poke@localhost:5432/poke"
