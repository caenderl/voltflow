# Anker Solix credentials - copy to .env and fill in
ANKERUSER="your@mail.com"
ANKERPASSWORD="your-password"   # special characters -> wrap in quotes!
ANKERCOUNTRY="DE"

# SMA inverter password (Speedwire "user" group). IP/interval are set in the UI.
SMA_PASSWORD="your-inverter-password"

# DB credentials (source of truth; used by the DB container and the apps)
POSTGRES_USER="voltflow"
POSTGRES_PASSWORD="voltflow"
POSTGRES_DB="voltflow"
# For apps running locally (outside Docker); inside containers the URL is built
# from the POSTGRES_* values with host "db" (see docker-compose.prod.yml).
DATABASE_URL="postgresql://voltflow:voltflow@localhost:5432/voltflow"

# Host docker group id, so the backend can read the docker socket for the admin
# "System" tab container list. It is host-specific — always read it off the
# server with `getent group docker` (108 on ours; docker.io from the Ubuntu
# archive picks the next free gid, the upstream docker-ce packages use 999).
# A wrong value fails silently: the backend logs `docker query failed: EACCES`
# once and the container list stays empty. Leave unset locally.
# Note: `.env` is not pushed by scripts/deploy.sh, so this must be set in the
# server's own ~/voltflow/.env. Changing it there re-creates every service that
# reads the env file (including db — volume-safe, but a few seconds of downtime).
DOCKER_GID="108"
