    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "^23.0.1",
    "@nx/js": "^23.0.0",
    "@nx/nest": "^23.0.1",
    "@nx/node": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/webpack": "23.0.1",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
